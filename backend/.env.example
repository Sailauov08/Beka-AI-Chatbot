PORT=5006
MONGO_URI=mongodb://127.0.0.1:27017/ai_chatbot_db
JWT_SECRET=change_this_to_random_long_secret

# AI: gemini (default) | groq
AI_PROVIDER=gemini

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_google_ai_studio_key
GEMINI_MODEL=gemini-2.0-flash-lite,gemini-2.0-flash,gemini-1.5-flash-8b

# Groq (тегін лимит) — https://console.groq.com/keys
# AI_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile,llama-3.1-8b-instant

SERVE_FRONTEND=true

# Production (Render):
# APP_URL=https://beka-ai-chatbot.onrender.com
# CLIENT_URL=https://beka-ai-chatbot.onrender.com

# ——— Email OTP (SMTP) ———
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=app_password
# SMTP_FROM=Beka AI <your@gmail.com>

# ——— Phone OTP (Twilio SMS) ———
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1...

# ——— OAuth (AUTH-ОРНАТУ.md) ———
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# VK_CLIENT_ID=
# VK_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=

# OTP dev mode: show code on screen when SMTP/SMS not configured
# OTP_DEV_MODE=false

# Lava.top (ТӨЛЕМ-ОРНАТУ.md)
# LAVA_API_KEY=
# LAVA_OFFER_ID=04b038ea-... (50₽ Бастау)
# LAVA_OFFER_ID_BASIC=04b038ea-...
# LAVA_OFFER_ID_PRO=... (120₽ — lava-да жаңа offer жасаңыз)
# LAVA_WEBHOOK_API_KEY=
# LAVA_CURRENCY=RUB
# LAVA_PERIODICITY=MONTHLY
# PREMIUM_DURATION_DAYS=30
# PREMIUM_DISPLAY_PRICE=990 ₽ / 30 күн
# OWNER_EMAIL=your@email.com
# LAVA_MERCHANT_EMAIL=lava_author@email.com
